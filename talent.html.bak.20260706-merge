<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>SEE 生命印迹 · 先天思维特质报告</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&display=swap');

:root {
  --bg: #0f0f28; --card: #161630; --border: #2a2a45;
  --text: #e0dcd4; --muted: #8a8590; --accent: #6b96ac;
  --accent2: #a08868; --gold: #b8a080; --danger: #e05555;
  --shadow: 0 2px 12px rgba(0,0,0,.2); --radius: 14px;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family: -apple-system, "PingFang SC", "Noto Sans SC", sans-serif; background: var(--bg); color: var(--text); line-height:1.7; min-height:100vh; }

/* Header */
.hero {
  background: linear-gradient(170deg, #0f0f28 0%, #162038 35%, #1a2440 60%, #1a2038 100%);
  color: #e0dcd4; padding: 40px 24px 0; text-align:center;
}
.hero-top, .hero .features { position: relative; z-index: 1; }
.hero-bg {
  margin-top: 20px; line-height: 0; opacity: 1;
}
.hero-bg img { width: 100%; max-width: 720px; height: auto; display: block; margin: 0 auto; }
.hero-top { display: flex; align-items: center; justify-content: center; gap: 14px; margin-bottom: 4px; }
.hero-logo {
  font-size: 2.6em; line-height: 1;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,.08));
}
.hero-brand { text-align: left; }
.hero-name {
  font-family: "Noto Serif SC", "Songti SC", serif;
  font-size: 1.7em; font-weight: 700; letter-spacing: .06em;
  line-height: 1.2; color: #f0ece2;
}
.hero-subtitle {
  font-size: .88em; letter-spacing: .15em; font-weight: 400;
  color: #a09888; margin-top: 2px;
}
.hero .features { display: flex; justify-content: center; gap: 12px; margin-top: 28px; }
.hero .feature {
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.1);
  border-radius: 14px; padding: 16px 14px; flex: 1; max-width: 180px;
  transition: all .2s; backdrop-filter: blur(4px);
}
.hero .feature:hover {
  background: rgba(255,255,255,.14); border-color: rgba(255,255,255,.25);
  transform: translateY(-1px);
}
.hero .feature-icon { font-size: 1.3em; }
.hero .feature-text { font-size: .82em; font-weight: 500; color: #d8d2c4; white-space: nowrap; }
@media (max-width: 420px) {
  .hero .features { gap: 6px; }
  .hero .feature { padding: 12px 8px; max-width: 120px; }
  .hero .feature-text { font-size: .7em; }
}

.container { max-width: 720px; margin: 0 auto; padding: 20px 12px; }
.card { background: var(--card); border-radius: var(--radius); padding: 16px; margin-bottom: 12px; box-shadow: var(--shadow); border: 1px solid var(--border); }
.report-content { padding: 16px; background: #1a1a35; border-radius: 10px; font-size: .9em; line-height: 1.8; max-height: 500px; overflow-y: auto; border: 1px solid #2a2a45; }
@media (max-width: 500px) {
  .container { padding: 12px 6px; }
  .card { padding: 12px 10px; border-radius: 10px; }
  .report-content { padding: 12px 10px; font-size: .85em; }
  .btn { padding: 10px 16px; font-size: .85em; }
  h2 { font-size: 1em; }
}
.card h2 { font-size: 1.1em; margin-bottom: 16px; display:flex; align-items:center; gap:8px; font-weight: 600; color: #e0dcd4; }

.step-badge { display:inline-flex; align-items:center; justify-content:center; width:28px; height:28px; border-radius:50%; background:var(--accent); color:#0f0f28; font-size:.8em; font-weight:700; margin-right:6px; flex-shrink:0; }

.upload-zone p, .upload-zone .icon { color: #8a8590; }

/* Upload */
.upload-zone { border: 2px dashed #3a3a55; border-radius: var(--radius); text-align: center; cursor: pointer; transition: all .2s; background: #1a1a38; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:200px; padding: 16px; }
.upload-zone:hover, .upload-zone.drag { border-color: var(--accent); background: #1e1e40; }
.upload-zone .icon { font-size: 2em; margin-bottom: 6px; }
.upload-zone p { color: var(--muted); font-size: .85em; }
.preview-img { max-width: 100%; max-height: 280px; border-radius: 8px; border: 1px solid var(--border); display: none; }
.preview-img.show { display: block; }

.btn { display: inline-flex; align-items:center; gap:6px; padding: 10px 22px; border: none; border-radius: 10px; font-size: .9em; font-weight: 500; cursor: pointer; transition: all .15s; }
.btn:disabled { opacity: .5; cursor: not-allowed; }
.btn-primary { background: var(--accent); color: #fff; box-shadow: 0 2px 8px rgba(107,150,172,.3); }
.btn-primary:hover:not(:disabled) { background: #5a8296; box-shadow: 0 4px 14px rgba(107,150,172,.4); transform: translateY(-1px); }
.btn-outline { background: transparent; color: var(--accent); border: 1.5px solid var(--accent); }
.btn-outline:hover { background: rgba(107,150,172,.1); }
.btn-sm { padding: 6px 16px; font-size: .8em; border-radius: 8px; }

/* Results */
.result-grid { display: flex; flex-direction: column; gap: 5px; }
.result-item { display: flex; align-items: center; gap: 10px; padding: 8px 14px; background: #1e1e3a; border-radius: 10px; font-size: .85em; cursor: pointer; transition: all .12s; border: 1.5px solid transparent; }
.result-item:hover { border-color: var(--accent); background: #242444; }
.result-item .q { flex: 1; min-width: 0; }
.result-item .ans { font-weight: 700; font-size: 1.1em; color: var(--accent); min-width: 32px; text-align: center; background: #1a2a38; border-radius: 8px; padding: 2px 8px; }
.result-item.low-conf { background: #2e1e1e; border-color: #553333; }
.result-item.low-conf .ans { color: var(--danger); background: #3e2020; }

.module-title { font-weight: 600; color: var(--accent2); margin: 14px 0 6px; font-size: .9em; padding-bottom: 3px; border-bottom: 1px solid #2a2a45; }
.report-content.loading { text-align:center; color: var(--muted); padding: 40px; border: none; }
.report-content h1 { font-family: "Noto Serif SC", serif; font-size: 1.3em; color: #e8dcc0; margin: 20px 0 16px; font-weight: 700; border-bottom: 1px solid #3a3a55; padding-bottom: 8px; }
.report-content h2 { font-family: "Noto Serif SC", serif; font-size: 1.1em; color: #d0c8a0; margin: 20px 0 10px; }
.report-content h3 { font-family: "Noto Serif SC", serif; font-size: .95em; color: #c0b898; margin: 14px 0 8px; font-weight: 600; }
.report-content p { margin-bottom: 8px; }
.report-content ul { margin: 8px 0; padding-left: 20px; }
.report-content li { margin-bottom: 4px; }

/* Extra reports */
.extra-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-top: 14px; }
@media (max-width: 500px) { .extra-cards { grid-template-columns: 1fr; } }
.extra-card { padding: 18px 14px; background: #1a1a35; border: 1.5px solid #2a2a45; border-radius: 12px; text-align: center; cursor: pointer; transition: all .2s; }
.extra-card:hover { border-color: var(--accent); background: #202040; box-shadow: 0 4px 16px rgba(0,0,0,.3); transform: translateY(-1px); }
.extra-card .icon { font-size: 1.5em; margin-bottom: 4px; }
.extra-card .title { font-weight: 600; font-size: .9em; color: #d8d0c0; }
.extra-card .desc { font-size: .75em; color: var(--muted); margin-top: 2px; }
.extra-card.loading { opacity: .6; pointer-events: none; }
.extra-card.done { border-color: var(--accent); background: #1a2a28; cursor: default; }
.extra-card.done .title { color: var(--accent); }

.flex-row { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
.hidden { display: none !important; }

#manualCard select, #manualCard input { background: #1a1a38; color: #e0dcd4; border-color: #3a3a55; }

/* --- Structured editing panel --- */
.structured-toggle {
  display: flex; gap: 0; margin-bottom: 16px;
  background: #1a1a38; border-radius: 8px; border: 1px solid var(--border);
  overflow: hidden;
}
.structured-toggle button {
  flex: 1; padding: 8px 16px; border: none; font-size: .82em;
  background: transparent; color: var(--muted); cursor: pointer;
  transition: all .15s;
}
.structured-toggle button.active {
  background: var(--accent); color: #fff; font-weight: 600;
}
.structured-toggle button:not(.active):hover {
  background: rgba(107,150,172,.15); color: var(--text);
}

.structured-panel { display: none; }
.structured-panel.show { display: block; }

.structured-section {
  background: #1a1a35; border: 1px solid var(--border);
  border-radius: 10px; padding: 14px; margin-bottom: 12px;
}
.structured-section .section-title {
  font-size: .85em; font-weight: 600; color: var(--accent2);
  margin-bottom: 10px; padding-bottom: 4px;
  border-bottom: 1px solid var(--border);
}

.field-grid-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.field-grid-3col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
@media (max-width: 500px) {
  .field-grid-2col { grid-template-columns: 1fr; }
  .field-grid-3col { grid-template-columns: 1fr; }
}

.field-row { display: flex; flex-direction: column; gap: 3px; }
.field-row label {
  font-size: .78em; color: var(--muted); font-weight: 500;
}
.field-row input, .field-row select {
  padding: 6px 10px; border-radius: 6px; border: 1.5px solid var(--border);
  background: #161630; color: var(--text); font-size: .85em;
}
.field-row input:focus, .field-row select:focus {
  border-color: var(--accent); outline: none;
}

.input-with-unit { display: flex; align-items: center; gap: 4px; }
.input-with-unit input { flex: 1; }
.input-with-unit span { color: var(--muted); font-size: .82em; }

/* Function area grid */
.func-grid {
  display: grid; gap: 6px;
  grid-template-columns: minmax(50px, 80px) 1fr 1fr;
}
.func-header {
  display: contents; font-size: .78em; color: var(--muted); font-weight: 600;
}
.func-header .func-label { grid-column: 1; }
.func-header .func-left { grid-column: 2; text-align: center; }
.func-header .func-right { grid-column: 3; text-align: center; }
.func-row { display: contents; }
.func-row .func-label {
  display: flex; align-items: center; font-size: .82em; color: var(--text);
  padding: 4px 0;
}
.func-cell {
  display: flex; gap: 4px; align-items: center;
  background: #1a1a38; border-radius: 6px; padding: 2px 6px;
  border: 1px solid transparent;
}
.func-cell input[type="number"] {
  width: 48px; padding: 4px; border: none; background: transparent;
  color: var(--text); font-size: .85em; text-align: center;
}
.func-cell .pattern-input {
  width: 44px; padding: 3px; border: none; background: transparent;
  color: var(--accent); font-size: .78em; text-transform: uppercase;
  text-align: center;
}
.func-cell:focus-within { border-color: var(--accent); }

.structured-status {
  font-size: .75em; color: var(--muted); margin-top: 8px;
  padding: 6px 10px; background: #1a1a38; border-radius: 6px;
}
</style>
<script src="tesseract.min.js"></script>
<script>
window.TESSERACT_CONFIG = {
  workerPath: 'tesseract/worker.min.js',
  langPath: 'https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/',
};
</script>
</head>
<body>

<div class="hero">
  <div class="hero-top">
    <div class="hero-logo">🧬</div>
    <div class="hero-brand">
      <div class="hero-name">SEE 生命印迹</div>
      <div class="hero-subtitle">元认知训练系统</div>
    </div>
  </div>
  <div class="features">
    <div class="feature" onclick="location.href='index.html'"><div class="feature-icon">🧠</div><div class="feature-text">思维画像报告</div></div>
    <div class="feature" style="background:rgba(255,255,255,.18);border-color:rgba(255,255,255,.3)"><div class="feature-icon">🌿</div><div class="feature-text">先天思维特质报告</div></div>
    <div class="feature" onclick="location.href='insight.html'"><div class="feature-icon">🪞</div><div class="feature-text">自我觉察陪伴</div></div>
  </div>
  <div class="hero-bg"><img src="hero_talent.jpg" alt=""></div>
</div>

<div class="container">

<!-- ====== STEP 1: Upload ====== -->
<div class="card">
  <h2><span class="step-badge">1</span> 上传你的先天天赋特质报告</h2>
  <div style="margin-bottom:12px;display:flex;gap:10px;align-items:center;flex-wrap:wrap">
    <label style="font-size:.85em;color:var(--muted);white-space:nowrap">🔑 用户码</label>
    <input type="text" id="userCode" placeholder="输入你的用户码" style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:.85em;background:#1a1a38;color:#e0dcd4;flex:1;max-width:240px" onchange="loadUserReports()">
    <button class="btn btn-outline btn-sm" onclick="loadUserReports()">加载</button>
    <label style="font-size:.85em;color:var(--muted);white-space:nowrap">👤 姓名 *</label>
    <input type="text" id="userName" placeholder="输入姓名" style="padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:.85em;background:#1a1a38;color:#e0dcd4;flex:1;max-width:220px" onchange="saveUserName()">
    <span style="font-size:.75em;color:var(--muted)">报告保存在当前设备浏览器，刷新不丢失；跨设备请重新生成或下载保存</span>
  </div>
  <div style="display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap">
    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()" style="flex:1;min-width:200px;position:relative;overflow:hidden">
      <div id="uploadPlaceholder">
        <div class="icon">📸</div>
        <p>点击或拖拽上传报告照片</p>
        <p style="font-size:.75em;margin-top:4px">支持 JPG/PNG，请拍摄清晰</p>
      </div>
      <img id="preview" class="preview-img" style="display:none;position:absolute;top:0;left:0;width:100%;height:100%;object-fit:contain">
    </div>
    <div style="flex-shrink:0;text-align:center">
      <div style="font-size:.75em;color:var(--muted);margin-bottom:4px">📋 上传样本参考</div>
      <img src="talent_sample.jpg" style="max-width:200px;max-height:200px;border-radius:8px;border:1px solid var(--border);cursor:pointer;object-fit:contain" onclick="window.open(this.src)" title="点击查看大图">
    </div>
  </div>
  <div class="hidden" id="savedReportsSection" style="margin-top:12px;padding:10px 14px;background:#1a1a38;border-radius:8px;font-size:.85em">
    <div style="color:var(--accent);margin-bottom:6px">📂 已保存的报告</div>
    <div id="savedReportsList"></div>
  </div>
  <input type="file" id="fileInput" accept="image/*" class="hidden" onchange="handleFile(this.files[0])">
  <div class="flex-row" style="margin-top:10px;align-items:center;gap:12px">
    <label style="font-size:.8em;color:var(--muted);white-space:nowrap">🎂 年龄 *</label>
    <input type="number" id="reportAge" value="" min="0" max="120" placeholder="必填" required style="width:60px;padding:5px 8px;border-radius:8px;border:1.5px solid var(--border);background:#1a1a38;color:#e0dcd4;font-size:.8em">
    <label style="font-size:.8em;color:var(--muted);white-space:nowrap;margin-left:8px">👤 对象</label>
    <select id="reportTarget" style="padding:6px 10px;border-radius:8px;border:1.5px solid var(--border);background:#1a1a38;color:#e0dcd4;font-size:.8em;cursor:pointer">
      <option value="self">🙋 本人</option>
      <option value="parent">👨‍👩‍👧 父母</option>
      <option value="global">🌍 全局视角</option>
    </select>
  </div>
  <div class="flex-row" style="margin-top:6px">
    <button class="btn btn-primary" id="btnBaiduOcr" disabled onclick="startBaiduOcrDraft()">☁️ 百度云识别文字草稿</button>
    
    <select id="reportStyle" style="padding:6px 10px;border-radius:8px;border:1.5px solid var(--border);background:#1a1a38;color:#e0dcd4;font-size:.8em;cursor:pointer">
      <option value="gentle">🌿 温和顾问</option>
      <option value="parent">💝 亲子顾问</option>
      <option value="direct">🎯 专业规划师</option>
      <option value="educator">📚 教育分析师</option>
      <option value="coach">⚡ 成长教练</option>
    </select>
    <span style="font-size:.8em;color:var(--muted)" id="uploadStatus"></span>
  </div>
  <div style="margin-top:8px;padding:10px 14px;background:#1a1a35;border:1px solid #3a3a55;border-radius:10px">
    <button class="btn btn-outline btn-sm" onclick="startManualStructured()" style="font-size:.75em">✏️ 手动填写结构化数据</button>
    <textarea id="directOcrInput" class="hidden" placeholder="在此粘贴先天测评报告的完整文字内容..."></textarea>
  </div>
</div>

<!-- ====== STRUCTURED EDITING PANEL ====== -->
<div class="card hidden" id="structuredPanelCard">
  <h2><span class="step-badge">📋</span> 核对结构化指标</h2>

  <!-- Structured-only view (raw text available via scroll to textarea) -->

  <!-- Structured view -->
  <div class="structured-panel" style="display:block" id="structuredView">
    <div id="structuredLoading" style="text-align:center;padding:20px;color:var(--muted)">
      ⏳ 正在解析结构化数据...
    </div>
    <div id="structuredContent" style="display:none">
      <!-- Filled dynamically by JS -->
    </div>
    <div id="structuredActions" style="display:none;margin-top:14px;text-align:center">
      <button class="btn btn-primary" onclick="generateFromStructured()" style="padding:12px 32px;font-size:.95em">📊 生成解读报告</button>
      <div style="font-size:.75em;color:var(--muted);margin-top:6px">使用上方编辑后的结构化数据生成报告</div>
    </div>
  </div>

  <div class="structured-status" id="structuredStatus"></div>
</div>

<!-- ====== STEP 2: Report ====== -->
<div class="card hidden" id="reportCard">
  <h2><span class="step-badge">2</span> 你的解读报告 <span style="float:right;display:flex;gap:4px"><button class="btn btn-outline btn-sm" onclick="downloadReport(null,'doc')" style="font-size:.65em;padding:3px 8px">📥 Word</button><button class="btn btn-outline btn-sm" onclick="downloadReport(null,'pdf')" style="font-size:.65em;padding:3px 8px">🖨️ PDF</button><span style="font-size:.6em;color:var(--muted)">📱推荐</span></span></h2>
  <div id="ocrProgress" style="font-size:.8em;color:var(--muted);margin-bottom:8px"></div>
  <div class="report-content loading" id="reportContent">正在生成...</div>
</div>
<!-- ====== Chat ====== -->
<div class="card" id="chatSection">
  <h2>💬 个性化补充与报告整合</h2>
  <div id="chatMessages" style="max-height:350px;overflow-y:auto;margin-bottom:10px;font-size:.85em;line-height:1.6"></div>
  <div class="flex-row" style="gap:8px;margin-bottom:10px">
    <input type="text" id="chatInput" placeholder="输入个性化补充或修正意见，将整合进最终报告" style="flex:1;padding:8px 12px;border-radius:8px;border:1.5px solid var(--border);background:#1a1a38;color:#e0dcd4;font-size:.85em" onkeydown="if(event.key==='Enter')sendChat()">
    <button class="btn btn-primary btn-sm" onclick="sendChat()">发送</button>
  </div>
  <button class="btn btn-primary" onclick="summarizeChat()" id="btnSummarize" style="display:block;width:100%;padding:14px;font-size:1em">📝 生成整合报告</button>
</div>
<div class="card">
  <h2>💫 关系合盘</h2>
  <div style="font-size:.82em;color:var(--muted);margin-bottom:10px">上传对方报告，生成双人关系解读</div>
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
    <div class="extra-card" onclick="startComposite('parent')" id="compositeParent">
      <div class="icon">👨‍👧</div><div class="title">亲子关系合盘</div>
      <div class="desc">上传孩子的报告</div>
      <div class="hidden" id="compositeParentStatus" style="font-size:.75em;margin-top:4px"></div>
    </div>
    <div class="extra-card" onclick="startComposite('partner')" id="compositePartner">
      <div class="icon">💑</div><div class="title">亲密关系合盘</div>
      <div class="desc">上传伴侣的报告</div>
      <div class="hidden" id="compositePartnerStatus" style="font-size:.75em;margin-top:4px"></div>
    </div>
    <div class="extra-card" onclick="startComposite('family')" id="compositeFamily">
      <div class="icon">👨‍👩‍👧</div><div class="title">家庭合盘</div>
      <div class="desc">上传家人的报告</div>
      <div class="hidden" id="compositeFamilyStatus" style="font-size:.75em;margin-top:4px"></div>
    </div>
  </div>
  <input type="file" id="compositeFile" accept="image/*" class="hidden" onchange="handleCompositeFile(this.files[0])">
</div>

</div>


</div>

<script>
const API_BASE = window.location.origin;
let state = {
  imageData: null, ocrText: '',
  reports: {}, reportOrder: [],
  totalCost: 0, recognitionDone: false,
  userCode: '',
  editMode: 'structured', structuredMetrics: null
};

function getUserCode() {
  var urlCode = new URLSearchParams(window.location.search).get('code') || '';
  if (urlCode) {
    sessionStorage.setItem('see_code_shared', urlCode);
    var inp = document.getElementById('userCode');
    if (inp) { inp.value = urlCode; inp.parentElement.classList.add('hidden'); }
    return urlCode;
  }
  return document.getElementById('userCode').value.trim() || sessionStorage.getItem('see_code_shared') || '';
}

function getUserName() {
  var el = document.getElementById('userName');
  return (el ? el.value.trim() : '') || sessionStorage.getItem('see_name_shared') || '';
}

function saveUserName() {
  var name = getUserName();
  if (name) sessionStorage.setItem('see_name_shared', name);
}

function getFileNameBase(fallback) {
  var name = getUserName();
  var code = getUserCode();
  var base = [name, code].filter(Boolean).join('_') || fallback || 'SEE_报告';
  return base.replace(/[\\/:*?"<>|]+/g, '_').replace(/\s+/g, '_');
}

function saveReports() {
  const code = getUserCode();
  if (!code) return;
  let versions = [];
  try { const s = localStorage.getItem('see_talent_reports_v2_' + code); if(s) versions = JSON.parse(s).versions||[]; } catch(e){}
  versions.push({
    time: new Date().toLocaleDateString('zh-CN') + ' ' + new Date().toLocaleTimeString('zh-CN', {hour:'2-digit',minute:'2-digit'}),
    hasTalent: !!state.reports.portrait,
    portrait: state.reports.portrait||'', learning: state.reports.learning||'', emotion: state.reports.emotion||'', potential: state.reports.potential||''
  });
  if (versions.length > 20) versions = versions.slice(-20);
  localStorage.setItem('see_talent_reports_v2_' + code, JSON.stringify({versions, time: new Date().toISOString()}));
  sessionStorage.setItem('see_code_shared', code);
}

function loadUserReports() {
  const code = getUserCode();
  if (!code) return;
  sessionStorage.setItem('see_code_shared', code);
  // Migrate old data
  try {
    const old = localStorage.getItem('see_talent_reports_' + code);
    if (old && !localStorage.getItem('see_talent_reports_v2_' + code)) {
      const d = JSON.parse(old);
      localStorage.setItem('see_talent_reports_v2_' + code, JSON.stringify({versions: [{
        time: d.time ? new Date(d.time).toLocaleDateString('zh-CN') : '历史报告',
        hasTalent: !!(d.reports||{}).portrait,
        portrait: (d.reports||{}).portrait||'',
        learning: (d.reports||{}).learning||'', emotion: (d.reports||{}).emotion||'', potential: (d.reports||{}).potential||''
      }], time: d.time||new Date().toISOString()}));
    }
  } catch(e){}
  const saved = localStorage.getItem('see_talent_reports_v2_' + code);
  if (saved) {
    try {
      const data = JSON.parse(saved);
      const versions = data.versions || [];
      if (versions.length > 0) {
        const last = versions[versions.length-1];
        state.reports = {portrait: last.portrait||'', learning: last.learning||'', emotion: last.emotion||'', potential: last.potential||''};
        state.reportOrder = Object.keys(state.reports).filter(k => state.reports[k]);
      }
      showSavedReports();
    } catch(e) {}
  } else {
    document.getElementById('savedReportsSection').classList.add('hidden');
  }
}

function showSavedReports() {
  const keys = Object.keys(state.reports);
  if (keys.length === 0) return;
  document.getElementById('savedReportsSection').classList.remove('hidden');
  const names = {portrait:'🧬 先天特质画像', learning:'📖 学习风格', emotion:'💫 情绪模式', potential:'🎯 潜能发展'};
  let html = '';
  keys.forEach(k => {
    html += `<span style="cursor:pointer;margin-right:12px;color:var(--accent)" onclick="viewSavedReport('${k}')">${names[k]||k}</span>`;
  });
  document.getElementById('savedReportsList').innerHTML = html;
}

function viewSavedReport(key) {
  if (state.reports[key]) {
    document.getElementById('reportCard').classList.remove('hidden');
    document.getElementById('reportContent').classList.remove('loading');
    document.getElementById('reportContent').innerHTML = parseMD(state.reports[key]);
    document.getElementById('chatSection').style.display='block';
