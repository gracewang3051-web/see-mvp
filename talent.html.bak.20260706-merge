function handleFile(file) {
  if (!file || !file.type.startsWith('image/')) return;
  const reader = new FileReader();
  reader.onload = e => {
    state.imageData = e.target.result;
    document.getElementById('uploadPlaceholder').style.display = 'none';
    var pv = document.getElementById('preview');
    pv.src = state.imageData;
    pv.style.display = 'block';
    var _br = document.getElementById('btnRecognize'); if(_br) _br.disabled = false;
    document.getElementById('btnBaiduOcr').disabled = false;
    document.getElementById('uploadStatus').textContent = file.name;
  };
  reader.readAsDataURL(file);
}

// 将 Baidu OCR region_values → extract_metrics 格式
function regionValuesToMetrics(rv) {
  function parseNum(s) { var n = parseFloat(s); return isNaN(n) ? null : n; }
  function parseScore(s) { var m = (s||'').match(/(\d+)/); return m ? parseInt(m[1]) : null; }
  function parsePattern(s) { var m = (s||'').match(/([A-Z][a-z]*)/); return m ? m[1] : null; }

  var m = {};
  m.trc = parseNum(rv.trc || rv.learning_potential_trc_value);
  m.atd = parseNum(rv.atd || rv.reaction_speed_atd_value);
  m.personality_type = rv.personality_type || null;
  m.behavior_mode = rv.behavior_mode || null;
  m.brain_balance = rv.brain_balance || null;

  var ch = {};
  if (rv.auditory_pct) ch.auditory = parseNum(rv.auditory_pct);
  if (rv.visual_pct) ch.visual = parseNum(rv.visual_pct);
  if (rv.kinesthetic_pct) ch.kinesthetic = parseNum(rv.kinesthetic_pct);
  if (Object.keys(ch).length) { m.learning_channels = ch; m.primary_channel = Object.keys(ch).reduce(function(a,b){return ch[a]>=ch[b]?a:b;}); }

  var scores = {}, patterns = {};
  var areaMap = [
    ['spirit_communication', 'spirit_left'],
    ['spirit_creative', 'spirit_right'],
    ['thinking_logic', 'thinking_left'],
    ['thinking_spatial', 'thinking_right'],
    ['body_discrimination', 'kinesthetic_left'],
    ['body_feeling', 'kinesthetic_right'],
    ['auditory_discrimination', 'auditory_left'],
    ['auditory_feeling', 'auditory_right'],
    ['visual_discrimination', 'visual_left'],
    ['visual_feeling', 'visual_right']
  ];
  for (var i = 0; i < areaMap.length; i++) {
    var regionKey = areaMap[i][0], engKey = areaMap[i][1];
    var val = rv[regionKey];
    if (!val) continue;
    var sc = parseScore(val), pt = parsePattern(val);
    if (sc !== null) scores[engKey] = sc;
    if (pt) patterns[engKey] = pt;
  }
  if (Object.keys(scores).length) {
    m.function_scores = scores;
    m.function_patterns = patterns;
    var sorted = Object.keys(scores).sort(function(a,b){return scores[b]-scores[a];});
    m.top_three_areas = sorted.slice(0,3);
    m.lowest_area = sorted[sorted.length-1];
  }
  return m;
}

function fillOcrDraft(text, sourceLabel, regionValues) {
  var draft = (text || '').trim();
  if (draft) document.getElementById('directOcrInput').value = draft;
  var hasRegions = regionValues && Object.keys(regionValues).length > 0;

  if (hasRegions) {
    // 结构化模式：report card 保持隐藏，由结构化面板主导
    document.getElementById('ocrProgress').style.display = 'block';
    document.getElementById('ocrProgress').textContent = '✅ ' + sourceLabel + '区域识别完成';
    if (draft) {
      var rawTextEl = document.getElementById('structuredRawText');
      if (rawTextEl) rawTextEl.value = draft;
      var metrics = regionValuesToMetrics(regionValues);
      state.structuredMetrics = metrics;
      showStructuredPanelWithMetrics(metrics);
    }
  } else {
    // 传统模式：原始文本为主
    document.getElementById('reportCard').classList.remove('hidden');
    document.getElementById('reportContent').classList.remove('loading');
    document.getElementById('reportContent').textContent = draft
      ? sourceLabel + '已识别出 ' + draft.length + ' 字文字草稿。请先在上方文本框核对、修正错字，再点击「用文本生成报告」。'
      : sourceLabel + '未识别到可用文字，请改用粘贴文本或重新拍摄。';
    document.getElementById('ocrProgress').style.display = 'block';
    document.getElementById('ocrProgress').textContent = draft
      ? '✅ ' + sourceLabel + '草稿已生成: ' + draft.length + '字，请先校对'
      : '❌ ' + sourceLabel + '未识别到可用文字';
    if (draft) {
      document.getElementById('directOcrInput').focus();
      var rawTextEl2 = document.getElementById('structuredRawText');
      if (rawTextEl2) rawTextEl2.value = draft;
      extractAndShowStructured(draft);
    }
  }
}

async function startBaiduOcrDraft() {
  if (!state.imageData) return;
  var btn = document.getElementById('btnBaiduOcr');
  btn.disabled = true;
  btn.textContent = '☁️ 百度云识别中...';
  document.getElementById('reportCard').classList.remove('hidden');
  document.getElementById('reportContent').classList.add('loading');
  document.getElementById('reportContent').textContent = '正在调用百度云识别图片文字（手机端约需10-30秒）...';
  document.getElementById('ocrProgress').style.display = 'block';
  document.getElementById('ocrProgress').textContent = '';
  var controller = new AbortController();
  var timer = setTimeout(function(){ controller.abort(); }, 90000);
  try {
    var resp = await fetch(API_BASE + '/api/baidu-ocr', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({image: state.imageData}),
      signal: controller.signal
    });
    clearTimeout(timer);
    var data = await resp.json();
    if (!resp.ok || data.error) throw new Error(data.error || ('HTTP ' + resp.status));
    state.ocrText = data.text || '';
    state.lastRegionValues = data.region_values || null;
    fillOcrDraft(state.ocrText, '百度云OCR', data.region_values);
  } catch(e) {
    clearTimeout(timer);
    document.getElementById('reportContent').classList.remove('loading');
    var errMsg = e.name === 'AbortError' ? '请求超时(90s)，图片可能过大，请尝试压缩后重试' : e.message;
    document.getElementById('reportContent').textContent = '百度云识别失败: ' + errMsg + '。请改用粘贴文本，或使用本地识别草稿。';
    document.getElementById('ocrProgress').textContent = '❌ 百度云识别失败';
  }
  btn.disabled = false;
  btn.textContent = '☁️ 百度云识别文字草稿';
}

async function runTesseractWithTimeout(imageData, onLog, timeoutMs) {
  var cfg = window.TESSERACT_CONFIG || {};
  var worker = null;
  var timedOut = false;
  var timer = null;
  var task = (async function() {
    var options = {
      workerPath: cfg.workerPath,
      langPath: cfg.langPath
    };
    if (onLog) options.logger = onLog;
    worker = await Tesseract.createWorker('chi_sim+eng', 1, options);
    if (timedOut) {
      try { await worker.terminate(); } catch(_) {}
      throw new Error('OCR超时(20s)');
    }
    return await worker.recognize(imageData);
  })();
  var timeout = new Promise(function(_, reject) {
    timer = setTimeout(function() {
      timedOut = true;
      if (worker) { try { worker.terminate(); } catch(_) {} }
      reject(new Error('OCR超时(20s)'));
    }, timeoutMs || 20000);
  });
  try {
    return await Promise.race([task, timeout]);
  } finally {
    clearTimeout(timer);
    if (worker) { try { await worker.terminate(); } catch(_) {} }
    task.catch(function(){});
  }
}

async function generateFromText() {
  var text = document.getElementById('directOcrInput').value.trim();
  if (!text) { alert('请先粘贴报告文本'); return; }
  var btn = document.getElementById('btnRecognize');
  document.getElementById('reportCard').classList.remove('hidden');
  document.getElementById('reportContent').classList.add('loading');
  document.getElementById('reportContent').textContent = '正在生成报告...';
  document.getElementById('ocrProgress').textContent = '📄 文本输入: ' + text.length + '字';
  state.ocrText = text;
  try {
    var payload = {ocrText: text, type: 'portrait', style: document.getElementById('reportStyle').value, age: parseInt(document.getElementById('reportAge').value), target: document.getElementById('reportTarget').value};
    var panelVisible = !document.getElementById('structuredPanelCard').classList.contains('hidden');
    if (panelVisible && document.getElementById('structuredContent').style.display !== 'none') {
      try {
        payload.structuredMetrics = collectStructuredMetrics();
        document.getElementById('ocrProgress').textContent = '📊 结构化模式: ' + countExtractedFields(payload.structuredMetrics) + ' 个字段';
      } catch(_) {}
    }
    await runTalentReportJob(payload, '正在生成报告...');
  } catch(e) {
    document.getElementById('reportContent').textContent = '生成失败: ' + e.message;
  }
}

async function generateFromStructured() {
  var metrics = collectStructuredMetrics();
  var age = parseInt(document.getElementById('reportAge').value);
  if (!age || age < 0) { alert('请先填写年龄'); return; }

  var missing = getStructuredMissingFields();
  if (missing.length > 0) {
    alert('还有未填写字段，无法生成报告：\n' + missing.slice(0, 12).join('\n') + (missing.length > 12 ? '\n...' : ''));
    updateStructuredCompletionState();
    return;
  }

  document.getElementById('reportCard').classList.remove('hidden');
  document.getElementById('reportContent').classList.add('loading');
  document.getElementById('reportContent').textContent = '正在使用结构化数据生成报告...';
  document.getElementById('ocrProgress').style.display = 'block';
  document.getElementById('ocrProgress').textContent = '📊 结构化数据模式 · 共 ' + countExtractedFields(metrics) + ' 个字段';

  try {
    await runTalentReportJob({
      ocrText: state.ocrText || '',
      structuredMetrics: metrics,
      type: 'portrait',
      style: document.getElementById('reportStyle').value,
      age: age,
      target: document.getElementById('reportTarget').value
    }, '正在使用结构化数据生成报告...');
  } catch(e) {
    document.getElementById('reportContent').classList.remove('loading');
    document.getElementById('reportContent').textContent = '生成失败: ' + e.message;
  }
}

async function runTalentReportJob(payload, loadingText) {
  document.getElementById('reportCard').classList.remove('hidden');
  document.getElementById('reportContent').classList.add('loading');
  document.getElementById('reportContent').textContent = loadingText || '正在生成报告...';
  document.getElementById('ocrProgress').style.display = 'block';
  document.getElementById('ocrProgress').textContent = '⏳ 报告生成中，请保持页面打开';

  var submit = await fetch(API_BASE + '/api/talent-job', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify(payload)
  });
  var submitData = await submit.json();
  if (!submit.ok || submitData.error) throw new Error(submitData.error || ('HTTP ' + submit.status));

  var jobId = submitData.jobId;
  var startedAt = Date.now();
  var lastAge = -1;

  while (true) {
    if (Date.now() - startedAt > 180000) throw new Error('生成超时，请稍后重试');
    await new Promise(function(resolve){ setTimeout(resolve, 2000); });
    var resp = await fetch(API_BASE + '/api/talent-job?id=' + encodeURIComponent(jobId));
    var data = await resp.json();
    if (!resp.ok || (data.status !== 'running' && data.error)) throw new Error(data.error || ('HTTP ' + resp.status));
    if (data.status === 'running') {
      if (data.age != null && data.age !== lastAge) {
        lastAge = data.age;
        document.getElementById('ocrProgress').textContent = '⏳ 报告生成中，已等待 ' + data.age + ' 秒';
      }
      continue;
    }
    if (data.status === 'error') throw new Error(data.error || '报告生成失败');

    var result = data.result || {};
    state.reports = {portrait: result.content || ''};
    state.reportOrder = ['portrait'];
    state.lastDebug = result.debug || null;
    saveReports();
    document.getElementById('reportContent').classList.remove('loading');
    document.getElementById('reportContent').innerHTML = renderStack();
    document.getElementById('ocrProgress').textContent = '✅ 解读报告已生成';
    showDebug(result.debug);
    document.getElementById('reportCard').scrollIntoView({behavior:'smooth', block:'start'});
    document.getElementById('chatSection').style.display = 'block';
    state.conversation = [];
    document.getElementById('chatMessages').innerHTML = '';
    document.getElementById('btnSummarize').style.display = 'block';
    return result;
  }
}

